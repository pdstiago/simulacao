						<Parameter>
							<Name><![CDATA[forceStatisticsCollection]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[FPSO fpso = (FPSO) agent;
fpso.tempoInicioProcessamento = time();

Instalacao inst = getInstalacaoPorNome(fpso.idInstalacaoSelecionada);
inst.numFPSOsEmFila--;
inst.numFPSOsEmProcessamento++;
inst.pesoEmProcessamento += fpso.pesoTon;

if (time() > fpso.tempoChegadaInstalacao) {
    fpso.ocorreuFila = true;
}

traceln("=== ATRACAÇÃO === Mês " + String.format("%.2f", time())
    + " | FPSO: " + fpso.sigla
    + " | Instalação: " + fpso.idInstalacaoSelecionada
    + " | Esperou fila: " + fpso.ocorreuFila
    + " | Tempo na fila: " + String.format("%.2f", time() - fpso.tempoChegadaInstalacao) + " meses"
    + " | Em processamento: " + inst.numFPSOsEmProcessamento);]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onAtExit]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[FPSO fpso = (FPSO) agent;
fpso.tempoSaidaInstalacao = time();

Instalacao inst = getInstalacaoPorNome(fpso.idInstalacaoSelecionada);
inst.numFPSOsEmProcessamento--;
inst.numFPSOsAtendidos++;
inst.pesoEmProcessamento -= fpso.pesoTon;

processarSeparacao(agent, fpso.idInstalacaoSelecionada);

traceln("=== FIM DESMANTELAMENTO === Mês " + String.format("%.2f", time())
    + " | FPSO: " + fpso.sigla
    + " | Instalação: " + fpso.idInstalacaoSelecionada
    + " | Tempo processamento: " + String.format("%.2f", time() - fpso.tempoInicioProcessamento) + " meses");]]></Code>
							</Value>
