String[] nomesInstalacoes = {"Atlântico Sul (EAS)", "Ecovix", "EISA", 
    "Enseada", "Inhaúma", "Mauá", "Mac Laren", "Porto do Açu"};

for (int col = 2; col <= 9; col++) {
    Instalacao inst = new Instalacao();
    
    for (int i = 0; i < 16; i++) {
        inst.contribuicoes[i] = new java.util.ArrayDeque<>();
    }
    
    inst.nome = nomesInstalacoes[col - 2];
    inst.estado = excelData.getCellStringValue("Instalações de reciclagem", 2, col);
    
    String latlon = excelData.getCellStringValue("Instalações de reciclagem", 3, col);
    String[] partes = latlon.split(",");
    inst.latitude = Double.parseDouble(partes[0].trim());
    inst.longitude = Double.parseDouble(partes[1].trim());
    
    inst.numEstruturas = (int) excelData.getCellNumericValue("Instalações de reciclagem", 4, col);
    inst.capArmazenamentoAnual = excelData.getCellNumericValue("Instalações de reciclagem", 5, col);
    inst.restricaoAcesso = excelData.getCellStringValue("Instalações de reciclagem", 6, col);
    
    listaInstalacoes.add(inst);
}

for (int i = 0; i < 28; i++) {
    Destinador dest = new Destinador();
    dest.tipoMaterial = "Ferroso";
    dest.razaoSocial = excelData.getCellStringValue("Destino-Ferroso", i + 2, 2);
    dest.estado = excelData.getCellStringValue("Destino-Ferroso", i + 2, 3);
    dest.latitude = excelData.getCellNumericValue("Destino-Ferroso", i + 2, 4);
    dest.longitude = excelData.getCellNumericValue("Destino-Ferroso", i + 2, 5);
    
    dest.capMinTonAno = excelData.getCellNumericValue("Destino-Ferroso", i + 2, 6);
    dest.capMaxTonAno = dest.capMinTonAno;
    dest.capMediaTonAno = dest.capMinTonAno;
    dest.capAtualAno = dest.capMinTonAno;
    listaDestinadores.add(dest);
}

int linhaFinal = 38;
for (int i = 0; i < linhaFinal; i++) {
    String material = excelData.getCellStringValue("Destinadores", i + 2, 1);
    if (material == null || material.isEmpty()) break;  // parar se linha vazia
    
    Destinador dest = new Destinador();
    if (material.equals("NãoFerroso")) dest.tipoMaterial = "NaoFerroso";
    else dest.tipoMaterial = material;
    
    dest.cnpj = excelData.getCellStringValue("Destinadores", i + 2, 2);
    dest.razaoSocial = excelData.getCellStringValue("Destinadores", i + 2, 3);
    dest.estado = excelData.getCellStringValue("Destinadores", i + 2, 4);
    dest.municipio = excelData.getCellStringValue("Destinadores", i + 2, 5);
    dest.participacaoMercado = excelData.getCellNumericValue("Destinadores", i + 2, 6);
    
    dest.capMinTonAno = excelData.getCellNumericValue("Destinadores", i + 2, 7) / 1000.0;
    dest.capMaxTonAno = excelData.getCellNumericValue("Destinadores", i + 2, 8) / 1000.0;
    dest.capMediaTonAno = excelData.getCellNumericValue("Destinadores", i + 2, 9) / 1000.0;
    
    // Geocodificar lat/lon pelo município
    double[] coords = geocodificarMunicipio(dest.municipio);
    dest.latitude = coords[0];
    dest.longitude = coords[1];
    
    listaDestinadores.add(dest);
}]]></StartupCode>
