						<Parameter>
							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[FPSO original = filaPendente.poll();  // pega e remove o primeiro da fila
FPSO fpso = (FPSO) agent;

fpso.sigla = original.sigla;
fpso.nome = original.nome;
fpso.bacia = original.bacia;
fpso.anoDescomissionamento = original.anoDescomissionamento;
fpso.latitude = original.latitude;
fpso.longitude = original.longitude;
fpso.pesoTon = original.pesoTon;

// Selecionar instalação mais próxima (Cenário Base)
double menorDist = Double.MAX_VALUE;
Instalacao selecionada = null;

for (Instalacao inst : listaInstalacoes) {
    if (inst.capArmazenamentoAnual < fpso.pesoTon) continue;
    
    double dist = calcularDistanciaKm(fpso.latitude, fpso.longitude,
                                       inst.latitude, inst.longitude);
    if (dist < menorDist) {
        menorDist = dist;
        selecionada = inst;
    }
}

fpso.idInstalacaoSelecionada = selecionada.nome;
fpso.distanciaReboque = menorDist;

// Calcular tempo de reboque
double velocidadeNos = triangular(3, 5, 4);
double velocidadeKmH = velocidadeNos * 1.852;
fpso.tempoReboque = menorDist / velocidadeKmH / (24.0 * 30.0);

traceln("=== SOURCE === Mês " + time() 
    + " | FPSO: " + fpso.sigla 
    + " | Peso: " + String.format("%.0f", fpso.pesoTon) + "t"
    + " | Destino: " + fpso.idInstalacaoSelecionada
    + " | Distância: " + String.format("%.1f", fpso.distanciaReboque) + " km"
    + " | Tempo reboque: " + String.format("%.4f", fpso.tempoReboque) + " meses");]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onDiscard]]></Name>
						</Parameter>
					</Parameters>
					<ReplicationFlag>false</ReplicationFlag>
					<Replication Class="CodeValue">
						<Code><![CDATA[100]]></Code>
					</Replication>
