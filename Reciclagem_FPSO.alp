				<EmbeddedObject>
					<Id>1777308603218</Id>
					<Name><![CDATA[destinador]]></Name>
					<X>470</X><Y>880</Y>
					<Label><X>-10</X><Y>-20</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<ActiveObjectClass>
						<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
						<ClassName><![CDATA[Sink]]></ClassName>
					</ActiveObjectClass>
					<GenericParameterSubstitute>
						<GenericParameterSubstituteReference>
							<PackageName><![CDATA[com.anylogic.libraries.processmodeling]]></PackageName>
							<ClassName><![CDATA[Sink]]></ClassName>
							<ItemName><![CDATA[1412336242929]]></ItemName>
						</GenericParameterSubstituteReference>
					</GenericParameterSubstitute>
					<Parameters>
						<Parameter>
							<Name><![CDATA[onEnter]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[Lote lote = (Lote) agent;
int i = lote.materialIdx;

double volumeTotalLote = 0;

for (Object[] c : lote.contribuicoes) {
    FPSO fpso = (FPSO) c[0];
    double qtd = (double) c[1];
    volumeTotalLote += qtd;

    double pendenteAntes = fpso.qtdPendente[i];
    fpso.qtdPendente[i] -= qtd;

    fpso.destinadorPorMaterial[i] = lote.destinador.razaoSocial;
    fpso.distanciaCaminhaoPorMaterial[i] = lote.distanciaKm;
    fpso.tempoCaminhaoPorMaterial[i] = lote.tempoMeses;

    if (fpso.qtdPendente[i] <= 1e-6 && pendenteAntes > 1e-6) {
        fpso.materiaisPendentes--;
        if (fpso.materiaisPendentes == 0) {
            fpso.tempoSaidaSistema = time();
            aguardarDestinacao.free(fpso);
        }
    }
}]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[destroyEntity]]></Name>
						</Parameter>
					</Parameters>
