			<Name><![CDATA[Destinador]]></Name>
			<AdditionalClassCode><![CDATA[// DADOS FIXOS (vindos do Excel)
public String tipoMaterial = "";
public String razaoSocial = "";
public String cnpj = "";
public String estado = "";
public String municipio = "";
public double latitude = 0;
public double longitude = 0;
public double participacaoMercado = 0;
public double capMinTonAno = 0;
public double capMaxTonAno = 0;
public double capMediaTonAno = 0;


// VARIÁVEIS DINÂMICAS (mudam durante a simulação)
public double capAtualAno = 0;          // capacidade sorteada para o ano corrente
public double volumeRecebidoNoAno = 0;  // toneladas já recebidas no ano corrente
public double volumeRecebidoNoMes = 0;  // toneladas recebidas no mês corrente (para log)
public double totalRecebidoHistorico = 0; // acumulado total desde o início

public boolean temCapacidade(double volumeAEnviar) {
    return (volumeRecebidoNoAno + volumeAEnviar) <= capAtualAno;
}]]></AdditionalClassCode>
