			<AdditionalClassCode><![CDATA[public int limiteFPSOsTeste = 3;  // mude para quantas quiser testar
public int fpsosInjetadas = 0;

public static final String[] NOMES_MATERIAIS = {
    "Ferroso", "NaoFerroso", "A-1", "A-3&C-25", "C-46",
    "B-3", "B-4", "C-3", "C-8", "C-9", "C-13", "C-14",
    "C-15", "C-50", "D-1", "D-2"
};

public static final double[] CAP_CAMINHAO = {
    30.0, 10.0, 5.0, 5.0, 5.0, 5.0, 5.0, 5.0,
    5.0, 5.0, 5.0, 5.0, 5.0, 5.0, 5.0, 5.0
};

public java.util.ArrayList<FPSO> listaFPSOs = new java.util.ArrayList<FPSO>();
public java.util.ArrayList<Instalacao> listaInstalacoes = new java.util.ArrayList<Instalacao>();
public java.util.ArrayList<Destinador> listaDestinadores = new java.util.ArrayList<Destinador>();
public java.util.LinkedList<FPSO> filaPendente = new java.util.LinkedList<FPSO>();

double calcularDistanciaKm(double lat1, double lon1, double lat2, double lon2) {
    double R = 6371.0; // raio da Terra em km
    double dLat = Math.toRadians(lat2 - lat1);
    double dLon = Math.toRadians(lon2 - lon1);
    double a = Math.sin(dLat/2) * Math.sin(dLat/2) +
               Math.cos(Math.toRadians(lat1)) * Math.cos(Math.toRadians(lat2)) *
               Math.sin(dLon/2) * Math.sin(dLon/2);
    double c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    return R * c;
}

public Instalacao getInstalacaoPorNome(String nome) {
    for (Instalacao inst : listaInstalacoes) {
        if (inst.nome.equals(nome)) return inst;
    }
    return null;
}

public void processarSeparacao(Agent agent, String nomeInstalacao) {
    FPSO fpso = (FPSO) agent;
    fpso.tempoSaidaInstalacao = time();

    // Separação de materiais (distribuições triangulares)
    double[][] pctParams = {
        {0.869,     0.977,     0.923},      // 0: Ferroso
        {0.01,      0.11,      0.06},       // 1: NãoFerroso
        {0.0012892, 0.0043833, 0.0028362},  // 2: A-1
        {0.0000150, 0.0000510, 0.0000330},  // 3: A-3&C-25
        {0.0000812, 0.0002762, 0.0001787},  // 4: C-46
        {0.0000016, 0.0000054, 0.0000035},  // 5: B-3
        {0.0000015, 0.0000052, 0.0000034},  // 6: B-4
        {0.0012717, 0.0043236, 0.0027977},  // 7: C-3
        {0.0000099, 0.0000338, 0.0000219},  // 8: C-8
        {0.0008548, 0.0029062, 0.0018805},  // 9: C-9
        {0.0000150, 0.0000510, 0.0000330},  // 10: C-13
        {0.0000081, 0.0000276, 0.0000178},  // 11: C-14
        {0.0000150, 0.0000510, 0.0000330},  // 12: C-15
        {0.0063412, 0.0215600, 0.0139506},  // 13: C-50
        {0.0000853, 0.0002899, 0.0001876},  // 14: D-1
        {0.0000106, 0.0000359, 0.0000232}   // 15: D-2
    };

    for (int i = 0; i < 16; i++) {
        double pct = triangular(pctParams[i][0], pctParams[i][1], pctParams[i][2]);
        fpso.qtdMateriais[i] = pct * fpso.pesoTon;
    }

    // Acumular nos estoques da instalação
    Instalacao inst = getInstalacaoPorNome(nomeInstalacao);
    for (int i = 0; i < 16; i++) {
	    inst.estoques[i] += fpso.qtdMateriais[i];
	   
	    if (fpso.qtdMateriais[i] > 0) {
	        inst.contribuicoes[i].addLast(new Object[]{ fpso, fpso.qtdMateriais[i] });
	        fpso.qtdPendente[i] = fpso.qtdMateriais[i];
	        fpso.materiaisPendentes++;
	    }
	}
    
    double somaTotal = 0;
    for (int i = 0; i < 16; i++) somaTotal += fpso.qtdMateriais[i];
    
    traceln("=== SEPARAÇÃO === Mês " + String.format("%.2f", time()) 
        + " | FPSO: " + fpso.sigla 
        + " | Instalação: " + nomeInstalacao
        + " | Ferroso: " + String.format("%.1f", fpso.qtdMateriais[0]) + "t"
        + " | NãoFerroso: " + String.format("%.1f", fpso.qtdMateriais[1]) + "t"
        + " | Total materiais: " + String.format("%.1f", somaTotal) + "t"
        + " | Peso original: " + String.format("%.1f", fpso.pesoTon) + "t");
}

public void despacharMaterial(Instalacao inst, int i) {
    String tipoMaterialBusca = NOMES_MATERIAIS[i];

    // Enviar caminhões enquanto houver material suficiente
    while (inst.estoques[i] > 1e-9) {
        double volumeAEnviar = Math.min(inst.estoques[i], CAP_CAMINHAO[i]);

        // Buscar destinador compatível mais próximo com capacidade
        Destinador selecionado = null;
        double menorDist = Double.MAX_VALUE;

        for (Destinador dest : listaDestinadores) {
            if (dest.tipoMaterial.equals(tipoMaterialBusca) 
                && dest.temCapacidade(volumeAEnviar)) {
                double dist = calcularDistanciaKm(inst.latitude, inst.longitude, 
                                                   dest.latitude, dest.longitude);
                if (dist < menorDist) {
                    menorDist = dist;
                    selecionado = dest;
                }
            }
        }

        // Se nenhum destinador tem capacidade, parar
        if (selecionado == null){
        	//traceln("=== DESPACHO BLOQUEADO === Mês " + String.format("%.2f", time())
           //     + " | Instalação: " + inst.nome
            //    + " | Material: " + tipoMaterialBusca
             //   + " | Estoque: " + String.format("%.2f", inst.estoques[i]) + "t"
             //   + " | Motivo: nenhum destinador com capacidade");
        	break;
        }
        
        Lote lote = new Lote();
        lote.destinador  = selecionado;
        lote.materialIdx = i;
        lote.distanciaKm = menorDist;
        lote.volumeTotal = volumeAEnviar;

        // Calcular tempo de transporte
        double velKmH = triangular(50, 70, 60);
        double tempoHoras = menorDist / velKmH;
        double tempoMeses = tempoHoras / (24.0 * 30.0);
		
		lote.tempoMeses = tempoMeses;
		
        double restante = volumeAEnviar;
        while (restante > 1e-9 && !inst.contribuicoes[i].isEmpty()) {
            Object[] c = inst.contribuicoes[i].peekFirst();
            FPSO contribuinte = (FPSO) c[0];
            double q = (double) c[1];

            if (q <= restante + 1e-9) {
                // Toda a contribuição entra no caminhão
                inst.contribuicoes[i].pollFirst();
                lote.contribuicoes.add(new Object[]{ contribuinte, q });
                restante -= q;
            } else {
                // Despacho parcial: parte vai, parte fica para o próximo caminhão
                c[1] = q - restante;
                lote.contribuicoes.add(new Object[]{ contribuinte, restante });
                restante = 0;
            }
        }
        
        // Atualizar estoques e contadores
        inst.estoques[i] -= volumeAEnviar;
        selecionado.volumeRecebidoNoAno += volumeAEnviar;
        selecionado.volumeRecebidoNoMes += volumeAEnviar;
        selecionado.totalRecebidoHistorico += volumeAEnviar;
    	
    	enterLote.take(lote);
    	
    	//traceln("=== DESPACHO === Mês " + String.format("%.2f", time())
         //   + " | Instalação: " + inst.nome
         //   + " | Material: " + tipoMaterialBusca
         //   + " | Volume: " + String.format("%.2f", volumeAEnviar) + "t"
         //   + " | Destinador: " + selecionado.razaoSocial
         //   + " | Distância: " + String.format("%.1f", menorDist) + " km"
         //   + " | Tempo transporte: " + String.format("%.4f", tempoMeses) + " meses"
          //  + " | Restante estoque: " + String.format("%.2f", inst.estoques[i]) + "t"
          //  + " | Destinador utilização: " + String.format("%.2f", selecionado.volumeRecebidoNoAno) 
          //  + "/" + String.format("%.2f", selecionado.capAtualAno) + " t/ano");
    }
}

public double[] geocodificarMunicipio(String municipio) {
    String m = municipio.toUpperCase().trim();
    
    if (m.equals("CAIEIRAS"))            return new double[]{-23.36, -46.74};
    if (m.equals("SAO JOSE DOS CAMPOS")) return new double[]{-23.18, -45.88};
    if (m.equals("SERRA"))               return new double[]{-20.13, -40.31};
    if (m.equals("UBERABA"))             return new double[]{-19.75, -47.93};
    if (m.equals("ROSARIO"))             return new double[]{-2.94,  -44.25};
    if (m.equals("CARIACICA"))           return new double[]{-20.26, -40.42};
    if (m.equals("VALINHOS"))            return new double[]{-22.97, -46.99};
    if (m.equals("SAO JOAO DEL REI"))    return new double[]{-21.13, -44.26};
    if (m.equals("JOAO PESSOA"))         return new double[]{-7.12,  -34.84};
    if (m.equals("INDAIATUBA"))          return new double[]{-23.09, -47.22};
    if (m.equals("GRAVATAI"))            return new double[]{-29.94, -50.99};
    if (m.equals("GUARULHOS"))           return new double[]{-23.45, -46.53};
    if (m.equals("ITAMBE"))              return new double[]{-23.66, -51.99};
    if (m.equals("LONDRINA"))            return new double[]{-23.31, -51.16};
    if (m.equals("CURITIBA"))            return new double[]{-25.43, -49.27};
    if (m.equals("BALSA NOVA"))          return new double[]{-25.58, -49.63};
    if (m.equals("RIO CLARO"))           return new double[]{-22.41, -47.56};
    if (m.equals("ITU"))                 return new double[]{-23.26, -47.30};
    if (m.equals("ALVORADA"))            return new double[]{-29.99, -51.08};
    if (m.equals("LAVRAS"))              return new double[]{-21.25, -45.00};
    if (m.equals("MACAE"))               return new double[]{-22.37, -41.79};
    if (m.equals("TAMARANA"))            return new double[]{-23.72, -51.10};
    if (m.equals("SUZANO"))              return new double[]{-23.54, -46.31};
    if (m.equals("MAGE"))                return new double[]{-22.65, -43.17};
    if (m.equals("ARACRUZ"))             return new double[]{-19.82, -40.27};
    if (m.equals("MAUA"))                return new double[]{-23.67, -46.46};
    if (m.equals("TRES LAGOAS"))         return new double[]{-20.75, -51.68};
    if (m.equals("AMERICANA"))           return new double[]{-22.74, -47.33};
    if (m.equals("CAPELA DE SANTANA"))   return new double[]{-29.70, -51.33};
    if (m.equals("PEDRO LEOPOLDO"))      return new double[]{-19.62, -44.04};
    if (m.equals("SAO JOSE DOS PINHAIS"))return new double[]{-25.53, -49.21};
    if (m.equals("SETE LAGOAS"))         return new double[]{-19.46, -44.25};
    if (m.equals("SOROCABA"))            return new double[]{-23.50, -47.46};
    
    traceln("AVISO: Município não geocodificado: " + municipio);
    return new double[]{0.0, 0.0};
}

public boolean liberandoEmAndamento = false;
public void tentarLiberar() {
    if (liberandoEmAndamento) return;
    liberandoEmAndamento = true;
    
    // Despachar tudo uma vez por instalação, antes de avaliar a fila
    java.util.HashSet<String> instalacoesNaFila = new java.util.HashSet<>();
    for (int idx = 0; idx < filaAtracacao.size(); idx++) {
        FPSO fp = (FPSO) filaAtracacao.get(idx);
        instalacoesNaFila.add(fp.idInstalacaoSelecionada);
    }
    for (String nomeInst : instalacoesNaFila) {
        Instalacao inst = getInstalacaoPorNome(nomeInst);
        for (int i = 0; i < 16; i++) despacharMaterial(inst, i); // Despache
    }
    
    // FPSOs que serão liberadas
    java.util.ArrayList<FPSO> paraLiberar = new java.util.ArrayList<>();
    // Contagem temporária de alocações planejadas por instalação
    java.util.HashMap<String, Integer> contAlocacoesPlanejadas = new java.util.HashMap<>();
    // Peso das alocações planejadas por instalação
    java.util.HashMap<String, Double> pesoAlocacoesPlanejadas = new java.util.HashMap<>();
    
    
    for (int idx = 0; idx < filaAtracacao.size(); idx++) {
        FPSO fpso = (FPSO) filaAtracacao.get(idx);
        Instalacao inst = getInstalacaoPorNome(fpso.idInstalacaoSelecionada);
        
        int jaAlocadas = contAlocacoesPlanejadas.getOrDefault(inst.nome, 0);
        
        // Estrutura livre (considerando as já planejadas)
        if (inst.numFPSOsEmProcessamento + jaAlocadas >= inst.numEstruturas) {
            traceln("=== BLOQUEADA POR ESTRUTURA === Mês " + String.format("%.2f", time())
                + " | FPSO: " + fpso.sigla
                + " | Instalação: " + inst.nome
                + " | Em processamento: " + inst.numFPSOsEmProcessamento
                + " | Já planejadas neste loop: " + jaAlocadas
                + " | Estruturas totais: " + inst.numEstruturas);
            continue;
        }
        
        // Capacidade de armazenamento
        double estoqueTotal = 0;
        for (int i = 0; i < 16; i++) estoqueTotal += inst.estoques[i];
        
        // pesoPlanejado = soma dos pesos das FPSOs já marcadas para liberação nesta passada
		double pesoPlanejado = pesoAlocacoesPlanejadas.getOrDefault(inst.nome, 0.0);
        double ocupacao = estoqueTotal + inst.pesoEmProcessamento + pesoPlanejado;
        
        if (ocupacao + fpso.pesoTon > inst.capArmazenamentoAnual) {
            traceln("=== BLOQUEADA POR ARMAZENAMENTO === Mês " + String.format("%.2f", time())
                + " | FPSO: " + fpso.sigla + " (" + String.format("%.0f", fpso.pesoTon) + "t)"
                + " | Instalação: " + inst.nome
                + " | Estoque: " + String.format("%.0f", estoqueTotal) + "t"
                + " | Em processamento: " + String.format("%.0f", inst.pesoEmProcessamento) + "t"
                + " | Planejado neste loop: " + String.format("%.0f", pesoPlanejado) + "t"
                + " | Ocupação total + nova FPSO: " + String.format("%.0f", ocupacao + fpso.pesoTon) + "t"
                + " | Capacidade: " + String.format("%.0f", inst.capArmazenamentoAnual) + "t"
                + " | Faltam: " + String.format("%.0f", (ocupacao + fpso.pesoTon) - inst.capArmazenamentoAnual) + "t");
            continue;
        }
        
        paraLiberar.add(fpso);
        contAlocacoesPlanejadas.put(inst.nome, jaAlocadas + 1);
        pesoAlocacoesPlanejadas.put(inst.nome, pesoPlanejado + fpso.pesoTon);
    }
    
    // Liberar fora do loop de decisão
    for (FPSO fpso : paraLiberar) {
        traceln("=== LIBERADA DA FILA === Mês " + String.format("%.2f", time())
            + " | FPSO: " + fpso.sigla
            + " | Instalação: " + fpso.idInstalacaoSelecionada);
        
        filaAtracacao.free(fpso);
    }
    
    liberandoEmAndamento = false;
}]]></AdditionalClassCode>
