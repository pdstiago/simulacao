			<AdditionalClassCode><![CDATA[// DADOS FIXOS (vindos do Excel)
public String sigla = "";
public String nome = "";
public String bacia = "";
public int anoDescomissionamento = 0;
public double latitude = 0;
public double longitude = 0;
public double pesoTon = 0;

// MATERIAIS GERADOS (calculados na etapa de separação)
// Array de 16 posições
public double[] qtdMateriais = new double[16];

// LOG / RASTREAMENTO (atualizados durante a simulação)
public String idInstalacaoSelecionada = "";
public double tempoReboque = 0;
public double distanciaReboque = 0;
public double tempoChegadaInstalacao = 0;
public double tempoInicioProcessamento = 0;
public double tempoSaidaInstalacao = 0;
public double tempoTotalSistema = 0;
public boolean ocorreuFila = false;

//
public double[] qtdPendente = new double[16];        // toneladas ainda não destinadas
public int materiaisPendentes = 0;                    // contador (de 16 → 0)
public String[] destinadorPorMaterial = new String[16];
public double[] distanciaCaminhaoPorMaterial = new double[16];
public double[] tempoCaminhaoPorMaterial = new double[16];
public double tempoSaidaSistema;                      // momento real do fim]]></AdditionalClassCode>
