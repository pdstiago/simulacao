			<Name><![CDATA[Instalacao]]></Name>
			<AdditionalClassCode><![CDATA[// DADOS FIXOS (vindos do Excel)
public String nome = "";
public String estado = "";
public double latitude = 0;
public double longitude = 0;
public int numEstruturas = 0;
public double capArmazenamentoAnual = 0;
public String restricaoAcesso = "";

// VARIÁVEIS DINÂMICAS (mudam durante a simulação)
public double pesoEmProcessamento = 0; // soma do pesoTon das FPSOs em desmantelamento

// ESTOQUES DE MATERIAIS (acumulados aguardando despacho)
// Array de 16 posições — mesma indexação da Parte 3.0
public double[] estoques = new double[16];

@SuppressWarnings("unchecked")
public java.util.ArrayDeque<Object[]>[] contribuicoes = new java.util.ArrayDeque[16];
// Cada entrada: { idFPSO, qtd }  — usar Object[] ou criar uma classe Contribuicao com 2 campos

// CONTROLE DE DESPACHO (regra de 1 mês de espera máxima)
// Registra o momento do último envio de cada material
public double[] tempoUltimoDespacho = new double[16];

// CONTADORES (atualizados durante a simulação)
public int numFPSOsAtendidos = 0;
public int numFPSOsEmFila = 0;
public int numFPSOsEmProcessamento = 0;]]></AdditionalClassCode>
